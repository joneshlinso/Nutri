# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────
# Replace with your actual MongoDB connection string
# Local:   mongodb://localhost:27017/nutriplanner
# Atlas:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nutriplanner?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/nutriplanner

# ─── JWT ────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
